          "_name": "content8",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section class=\"content8\" group=\"Content\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"12\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Stylized\" name=\"stylizedCounters\" checked>\n        <input type=\"checkbox\" title=\"Mark\" name=\"mark\" condition=\"stylizedCounters\">\n        <select title=\"Type\" name=\"countersType\" condition=\"stylizedCounters\">\n            <option value=\"default\" selected>Сircle Fill</option>\n            <option value=\"circle\">Circle</option>\n            <option value=\"square\">Square</option>\n        </select>\n        <input type=\"color\" name=\"iconColor\" title=\"Color\" value=\"#6592e6\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#ffffff\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"counter-container col-md-12 col-lg-{{textWidth}}\">\n                <h4 class=\"mbr-section-title mbr-fonts-style mb-4\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\">Selected papers on KL led by or with major contributions from the ACL</h4>\n                <div class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text\" data-multiline mbr-article>\n                    <ul><li><a href=\"https://ui.adsabs.harvard.edu/abs/2022arXiv220911811P/abstract\" class=\"text-primary\" target=\"_blank\">Kinematic Lensing Inference I: Characterizing Shape Noise with Simulated Analyses</a><br>Pranjal R., S. ; Krause, Elisabeth ; Huang, Hung-Jin ; Huff, Eric ; Xu, Jiachuan ; Eifler, Tim ; Everett, Spencer (2022)&nbsp;</li><li><a href=\"https://ui.adsabs.harvard.edu/abs/2022arXiv220100739X/abstract\" class=\"text-primary\" target=\"_blank\">Kinematic Lensing with the Roman Space Telescope</a><br>Xu, Jiachuan ; Eifler, Tim ; Huff, Eric ; Pranjal R., S. ; Huang, Hung-Jin ; Everett, Spencer ; Krause, Elisabeth (2022)</li><li><a href=\"https://ui.adsabs.harvard.edu/abs/2013arXiv1311.1489H/abstract\" class=\"text-primary\" target=\"_blank\">Cosmic Shear without shape noise</a><br>Huff, Eric M. ; Krause, Elisabeth ; Eifler, Tim ; Fang, Xiao ; George, Matthew R. ; Schlegel, David (2013/2019)</li></ul><ul>\n                    </ul>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
